generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Secretary {
  id       String @id @default(cuid())
  username String @unique
  password String
  role     String @default("geral")
}

model Teacher {
  id             String           @id @default(cuid())
  name           String
  email          String
  phone          String
  role           String           @default("geral")
  subjects       TeacherSubject[]
  availabilities Availability[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Subject {
  id            String           @id @default(cuid())
  name          String
  grade         String
  teachers      TeacherSubject[]
  examSchedules ExamSchedule[]
}

model TeacherSubject {
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
  @@id([teacherId, subjectId])
}

model Availability {
  id           String        @id @default(cuid())
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId    String
  dayOfWeek    Int
  specificDate DateTime?
  isSpecial    Boolean       @default(false)
  startTime    String
  endTime      String
  active       Boolean       @default(true)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model Appointment {
  id             String       @id @default(cuid())
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  availabilityId String
  date           DateTime
  startTime      String
  endTime        String
  parentName     String
  parentEmail    String
  parentPhone    String
  reason         String
  studentName    String
  studentGrade   String
  subjectName    String       @default("")
  status         String       @default("confirmed")
  createdAt      DateTime     @default(now())
}

// ── Segunda Chamada ──────────────────────────────────────

model ExamSchedule {
  id          String        @id @default(cuid())
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String
  subjectName String
  grade       String
  date        DateTime
  startTime   String
  endTime     String
  role        String        @default("geral")
  active      Boolean       @default(true)
  bookings    ExamBooking[]
  createdAt   DateTime      @default(now())
}

model ExamBooking {
  id             String       @id @default(cuid())
  examSchedule   ExamSchedule @relation(fields: [examScheduleId], references: [id], onDelete: Cascade)
  examScheduleId String

  parentName   String
  parentEmail  String
  parentPhone  String
  studentName  String
  studentGrade String

  // Status: PENDING | APPROVED | REJECTED
  status   String  @default("PENDING")

  // Justificativa
  justified Boolean?
  reason    String?   // "doenca" | "luto" | null
  lutoText  String?   // só quando reason === "luto"
  fileUrl   String?   // URL Cloudinary do comprovante/atestado

  createdAt DateTime @default(now())
}
