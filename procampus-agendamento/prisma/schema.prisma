// ============================================================
// ARQUIVO: prisma/schema.prisma
// CAMINHO: procampus-agendamento/prisma/schema.prisma
// SUBSTITUA o arquivo inteiro
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Secretary {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Teacher {
  id             String         @id @default(cuid())
  name           String
  email          String
  phone          String
  subjects       TeacherSubject[]
  availabilities Availability[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Subject {
  id       String           @id @default(cuid())
  name     String
  grade    String
  teachers TeacherSubject[]
}

model TeacherSubject {
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId String
  @@id([teacherId, subjectId])
}

// Disponibilidade RECORRENTE — ex: toda Terça das 08:00 às 10:00
model Availability {
  id        String        @id @default(cuid())
  teacher   Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  dayOfWeek Int           // 0=Dom 1=Seg 2=Ter 3=Qua 4=Qui 5=Sex 6=Sáb
  startTime String        // "08:00"
  endTime   String        // "10:00"
  active    Boolean       @default(true)
  appointments Appointment[]
  createdAt DateTime      @default(now())
}

// Agendamento — guarda o dia ESPECÍFICO da ocorrência
model Appointment {
  id             String       @id @default(cuid())
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  availabilityId String
  date           DateTime     // data específica da reunião (ex: 2025-01-21)
  startTime      String       // "08:00" — qual slot dentro do bloco
  endTime        String       // "08:30"
  parentName     String
  parentEmail    String
  parentPhone    String
  reason         String
  studentName    String
  studentGrade   String
  subjectName    String   @default("")
  status         String       @default("confirmed") // confirmed | cancelled
  createdAt      DateTime     @default(now())

  @@unique([availabilityId, date, startTime]) // impede duplicata no mesmo slot
}